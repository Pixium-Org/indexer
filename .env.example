# Stellar RPC connection
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
CONTRACT_ID=<canvas_contract_address>

# Indexer polling loop
START_LEDGER=<ledger_to_start_indexing_from>
POLL_INTERVAL_MS=5000

# Postgres (cursor persistence, wired up in this change)
DATABASE_URL=postgresql://user:password@localhost:5432/pixium

# Not wired up yet — reserved for the Redis canvas-cache follow-up
REDIS_URL=redis://localhost:6379
